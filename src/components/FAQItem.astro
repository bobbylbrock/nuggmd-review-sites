---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details class="border border-nugg-block1 rounded-lg overflow-hidden mb-3">
  <summary class="font-semibold text-nugg-blue px-5 py-4 bg-white hover:bg-blue-50 cursor-pointer flex items-center justify-between gap-4 list-none select-none">
    <span>{question}</span>
    <span class="chevron text-nugg-blue text-xl leading-none flex-shrink-0 transition-transform duration-200">›</span>
  </summary>
  <div class="faq-answer px-5 py-4 bg-white text-nugg-text text-sm leading-relaxed border-t border-nugg-block1">
    {answer}
  </div>
</details>

<style>
  details[open] .chevron {
    transform: rotate(90deg);
  }
  summary::-webkit-details-marker {
    display: none;
  }
</style>
