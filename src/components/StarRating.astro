---
interface Props {
  rating: number;
  max?: number;
  size?: 'sm' | 'md' | 'lg';
}

const { rating, max = 5, size = 'md' } = Astro.props;
const fullStars = Math.floor(rating);
const hasHalf = rating % 1 >= 0.5;
const emptyStars = max - fullStars - (hasHalf ? 1 : 0);

const sizeClass = {
  sm: 'text-base',
  md: 'text-xl',
  lg: 'text-3xl',
}[size];
---

<span class={`stars inline-flex items-center gap-0.5 ${sizeClass}`} aria-label={`${rating} out of ${max} stars`} role="img">
  {Array.from({ length: fullStars }).map(() => (
    <span class="text-nugg-error">★</span>
  ))}
  {hasHalf && <span class="text-nugg-error">½</span>}
  {Array.from({ length: emptyStars }).map(() => (
    <span class="text-nugg-block1">★</span>
  ))}
</span>
