---
import Base from '../../layouts/Base.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import StarRating from '../../components/StarRating.astro';
import allReviews from '../../data/reviews.json';

export async function getStaticPaths({ paginate }) {
  const variant = import.meta.env.PUBLIC_SITE_VARIANT ?? 'primary';
  let sorted = [...allReviews];

  if (variant === 'blue-red') {
    sorted.sort((a, b) => b.rating - a.rating || new Date(b.date).getTime() - new Date(a.date).getTime());
  } else if (variant === 'light') {
    const order: Record<string, number> = { Google: 0, Trustpilot: 1, BBB: 2 };
    sorted.sort((a, b) =>
      (order[a.platform] ?? 3) - (order[b.platform] ?? 3) ||
      new Date(b.date).getTime() - new Date(a.date).getTime()
    );
  }

  return paginate(sorted, { pageSize: 50 });
}

const variant = import.meta.env.PUBLIC_SITE_VARIANT ?? 'primary';
const reviewGridCols = variant === 'blue-red'
  ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-10'
  : variant === 'light'
    ? 'grid grid-cols-1 md:grid-cols-2 gap-6 mb-10'
    : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10';

const { page } = Astro.props;
const reviews = page.data;
const totalReviews = allReviews.length;
const avgRating = (allReviews.reduce((sum, r) => sum + r.rating, 0) / allReviews.length).toFixed(1);

const googleReviews = allReviews.filter(r => r.platform === 'Google');
const tpReviews = allReviews.filter(r => r.platform === 'Trustpilot');
const bbbReviews = allReviews.filter(r => r.platform === 'BBB');

const platforms = [
  { name: 'Google', count: googleReviews.length, avg: (googleReviews.reduce((s, r) => s + r.rating, 0) / googleReviews.length).toFixed(1) },
  { name: 'Trustpilot', count: tpReviews.length, avg: (tpReviews.reduce((s, r) => s + r.rating, 0) / tpReviews.length).toFixed(1) },
  { name: 'BBB', count: bbbReviews.length, avg: (bbbReviews.reduce((s, r) => s + r.rating, 0) / bbbReviews.length).toFixed(1) },
];

const isFirst = page.currentPage === 1;

const h1s: Record<string, string> = {
  primary:   'NuggMD Patient Reviews',
  'blue-red': 'Browse All NuggMD Patient Reviews',
  light:     'NuggMD Patient Testimonials',
};
const ctaH2s: Record<string, string> = {
  primary:   'Ready to Join 1.3M+ NuggMD Patients?',
  'blue-red': 'Join Over 1.3 Million Patients Nationwide',
  light:     'Start Your Medical Card Application Today',
};
const reviewsH1  = h1s[variant]   ?? h1s.primary;
const reviewsCta = ctaH2s[variant] ?? ctaH2s.primary;

const pageTitle = isFirst
  ? variant === 'light'
    ? `NuggMD Patient Testimonials — ${totalReviews} Real Experiences`
    : variant === 'blue-red'
      ? `NuggMD Reviews — ${totalReviews} Verified Patient Testimonials`
      : `NuggMD Patient Reviews — ${totalReviews} Verified Testimonials`
  : `${reviewsH1} — Page ${page.currentPage} of ${page.lastPage}`;

const pageDesc = isFirst
  ? variant === 'light'
    ? `Browse ${totalReviews} real NuggMD patient testimonials. ${avgRating}★ average across Google, Trustpilot, and BBB. HIPAA-compliant telemedicine in 31 states.`
    : variant === 'blue-red'
      ? `${totalReviews} verified NuggMD patient reviews sorted by highest rating. ${avgRating}★ average across Google, Trustpilot, and BBB.`
      : `Read ${totalReviews} verified patient reviews for NuggMD. ${avgRating}★ average rating across Google, Trustpilot, and BBB.`
  : `NuggMD patient reviews — page ${page.currentPage} of ${page.lastPage}. Real testimonials from verified patients across 31 states.`;

const reviewListSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'NuggMD',
  url: 'https://www.nuggmd.com',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: avgRating,
    reviewCount: String(totalReviews),
    bestRating: '5',
    worstRating: '1',
  },
  review: reviews.map((review) => ({
    '@type': 'Review',
    reviewBody: review.body,
    datePublished: review.date,
    author: { '@type': 'Person', name: review.author },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: review.rating,
      bestRating: 5,
      worstRating: 1,
    },
  })),
};
---

<Base title={pageTitle} description={pageDesc} schema={reviewListSchema}>

  <!-- Hero -->
  <section class="bg-nugg-dark text-white py-14 px-4">
    <div class="container-site text-center">
      <h1 class="text-white mb-4">{reviewsH1}</h1>
      <p class="text-nugg-tint text-lg max-w-2xl mx-auto mb-6">
        Real, verified reviews from NuggMD patients across 31 states. Every review represents a real patient experience with our telemedicine platform.
      </p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <div class="flex items-center gap-2">
          <StarRating rating={4.9} size="md" />
          <span class="text-white font-bold">{avgRating} / 5 average</span>
        </div>
        <span class="text-nugg-tint">·</span>
        <span class="text-nugg-tint">{totalReviews.toLocaleString()} verified reviews</span>
        <span class="text-nugg-tint">·</span>
        <span class="text-nugg-tint">Page {page.currentPage} of {page.lastPage}</span>
      </div>
    </div>
  </section>

  <!-- Platform stats bar -->
  <section class="bg-nugg-blue py-5 px-4">
    <div class="container-site">
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-12">
        {platforms.map(({ name, count, avg }) => (
          <div class="text-center">
            <p class="text-white font-bold">{name}</p>
            <p class="text-nugg-tint text-sm">{avg}★ avg · {count.toLocaleString()} reviews</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- External profiles -->
  <section class="section-gray py-8 px-4">
    <div class="container-site max-w-2xl mx-auto text-center">
      <p class="text-nugg-tint text-sm font-semibold uppercase tracking-widest mb-3">Verified on</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="https://www.google.com/search?q=NuggMD+reviews" target="_blank" rel="noopener noreferrer" class="badge badge-google py-2 px-5 text-sm font-semibold rounded-brand">Google Reviews</a>
        <a href="https://www.trustpilot.com/review/www.nuggmd.com" target="_blank" rel="noopener noreferrer" class="badge badge-trustpilot py-2 px-5 text-sm font-semibold rounded-brand">Trustpilot</a>
        <a href="https://www.bbb.org/us/de/wilmington/profile/medical-marijuana-card/lfg-enterprises-inc-1216-1268676/customer-reviews" target="_blank" rel="noopener noreferrer" class="badge badge-bbb py-2 px-5 text-sm font-semibold rounded-brand">BBB Profile</a>
      </div>
    </div>
  </section>

  <!-- Reviews grid -->
  <section class="section-white py-16 px-4">
    <div class="container-site">
      <div class={`${reviewGridCols}`} itemscope itemtype="https://schema.org/ItemList">
        {reviews.map((review) => (
          <ReviewCard review={review} />
        ))}
      </div>

      <!-- Pagination -->
      <nav class="flex items-center justify-center gap-3 flex-wrap pt-6 border-t border-nugg-block1" aria-label="Review pages">
        {page.url.prev && (
          <a href={page.url.prev} class="btn-secondary px-5 py-2 text-sm">← Previous</a>
        )}

        <div class="flex items-center gap-1 flex-wrap justify-center">
          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) => {
            const isActive = num === page.currentPage;
            const url = num === 1 ? '/reviews/' : `/reviews/${num}/`;
            return (
              <a
                href={url}
                class={`w-9 h-9 flex items-center justify-center rounded-brand text-sm font-semibold transition-colors ${
                  isActive
                    ? 'bg-nugg-blue text-white'
                    : 'text-nugg-blue hover:bg-nugg-block1'
                }`}
                aria-current={isActive ? 'page' : undefined}
              >
                {num}
              </a>
            );
          })}
        </div>

        {page.url.next && (
          <a href={page.url.next} class="btn-secondary px-5 py-2 text-sm">Next →</a>
        )}
      </nav>

      <p class="text-center text-nugg-tint text-sm mt-4">
        Showing reviews {(page.currentPage - 1) * 50 + 1}–{Math.min(page.currentPage * 50, totalReviews)} of {totalReviews.toLocaleString()}
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-nugg-blue text-white py-16 px-4 text-center">
    <div class="container-site max-w-xl mx-auto">
      <h2 class="text-white mb-4">{reviewsCta}</h2>
      <p class="text-nugg-tint mb-6">
        Fast, private, and HIPAA-compliant. You only pay if approved.
      </p>
      <a
        href="https://app.nuggmd.com/v2/signup/email?promo_code=TRYME20&utm_campaign=reviewlandingpages"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary px-8 py-3"
      >
        Get 20% Off — Code TRYME20
      </a>
    </div>
  </section>
</Base>
