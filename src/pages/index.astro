---
import Base from '../layouts/Base.astro';
import ReviewCard from '../components/ReviewCard.astro';
import StarRating from '../components/StarRating.astro';
import FAQItem from '../components/FAQItem.astro';
import reviews from '../data/reviews.json';
import faqs from '../data/faqs.json';

const variant = import.meta.env.PUBLIC_SITE_VARIANT ?? 'primary';

// Featured reviews: primary = first 6, blue-red = highest rated, light = first 6 with text body
let featuredReviews;
if (variant === 'blue-red') {
  featuredReviews = [...reviews].sort((a, b) => b.rating - a.rating || new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 8);
} else if (variant === 'light') {
  featuredReviews = reviews.filter((r) => r.body?.trim()).slice(0, 6);
} else {
  featuredReviews = reviews.slice(0, 6);
}

const generalFaqs = faqs.find((f) => f.state === 'General');
const previewFaqs = generalFaqs?.sections[0]?.faqs.slice(0, 4) ?? [];
const stateEntries = faqs.filter((f) => f.state !== 'General').sort((a, b) => a.state.localeCompare(b.state));

// Dynamic verified count — floored to nearest 100 so the "+" is always honest
const verifiedCount   = reviews.length;
const verifiedDisplay = `${(Math.floor(verifiedCount / 100) * 100).toLocaleString()}+`;

// Per-variant copy
const copy = {
  primary: {
    metaTitle:    'NuggMD Patient Reviews — Trusted Medical Cannabis Telemedicine',
    metaDesc:     `Read ${verifiedDisplay} verified patient reviews for NuggMD — all from recent years across Google, Trustpilot, and BBB. 4.9★ average. NuggMD has earned 10,000+ reviews since founding.`,
    h1:           'Real Reviews from Real NuggMD Patients',
    h2Reviews:    'What Patients Are Saying',
    h2Faq:        'Common Questions About NuggMD',
    h2Cta:        'Ready to Get Your Medical Card?',
    heroP:        'NuggMD is America\'s most trusted telemedicine platform for medical cannabis evaluations. Join over 1.3 million patients who\'ve gotten their card online — fast, private, and HIPAA-compliant.',
    reviewsP:     'Thousands of patients trust NuggMD for fast, professional, and compassionate medical cannabis evaluations.',
    faqP:         'Everything you need to know before getting your medical cannabis card online.',
    howItWorksP:  'Get your medical cannabis card in three simple steps — completely online.',
    step1P:       'Answer a few health questions, upload your ID, and complete payment — all in minutes.',
    step2P:       'Connect face-to-face with a licensed physician via secure video. Most visits take under 10 minutes.',
    step3P:       'Receive your recommendation and state registration instructions immediately. No approval, no charge.',
    statesP:      'Select your state to view state-specific FAQs, eligibility requirements, and card renewal information.',
    ctaP:         'Join over 1.3 million patients who\'ve trusted NuggMD for fast, secure, and compassionate medical cannabis evaluations. You only pay if approved.',
    ctaFooter:    'Available 8 AM – 10 PM daily  ·  HIPAA Compliant  ·  No approval = No charge',
  },
  'blue-red': {
    metaTitle:    'NuggMD Reviews | Verified Patient Testimonials Across 31 States',
    metaDesc:     `Verified NuggMD patient reviews across Google, Trustpilot, and BBB — ${verifiedDisplay} testimonials and a 4.9★ average across 31 states. HIPAA-compliant telemedicine.`,
    h1:           'Verified NuggMD Patient Reviews',
    h2Reviews:    'Hear Directly From Our Patients',
    h2Faq:        'Frequently Asked Questions About NuggMD',
    h2Cta:        'Join Over 1.3 Million Patients Nationwide',
    heroP:        'NuggMD connects patients with state-licensed physicians for medical cannabis evaluations entirely online. Over 1.3 million approvals across 31 states — secure, HIPAA-compliant, and available today.',
    reviewsP:     'Browse verified testimonials from NuggMD patients across Google, Trustpilot, and BBB — real experiences from real people in 31 states.',
    faqP:         'Have questions about the process, pricing, or eligibility? Find answers to the most common questions about NuggMD below.',
    howItWorksP:  'NuggMD\'s telemedicine process is straightforward: register, see a licensed doctor, and receive your recommendation — no office visit required.',
    step1P:       'Create your account, complete a brief health intake, and submit your ID for verification — takes under five minutes.',
    step2P:       'A state-licensed physician reviews your intake and meets with you via encrypted video. Most consultations are completed in under ten minutes.',
    step3P:       'If approved, your physician\'s recommendation is issued immediately along with step-by-step instructions for completing your state registration.',
    statesP:      'NuggMD operates in 31 states. Choose yours below to see local requirements, qualifying conditions, and renewal details.',
    ctaP:         'NuggMD has helped over 1.3 million patients get their medical cannabis card online. Board-certified physicians, same-day recommendations, and a no-approval-no-charge guarantee.',
    ctaFooter:    'Appointments available 8 AM – 10 PM  ·  Encrypted & HIPAA-compliant  ·  No charge without approval',
  },
  light: {
    metaTitle:    'NuggMD Patient Testimonials | Real Experiences from Verified Patients',
    metaDesc:     `${verifiedDisplay} real patient testimonials for NuggMD telemedicine — HIPAA-compliant medical cannabis evaluations available in 31 states. See what patients are saying on Google, Trustpilot, and BBB.`,
    h1:           'What NuggMD Patients Are Saying',
    h2Reviews:    'Patient Testimonials by Platform',
    h2Faq:        'Have Questions About NuggMD?',
    h2Cta:        'Start Your Medical Card Application',
    heroP:        'Millions of patients have trusted NuggMD to connect them with a licensed doctor for their medical cannabis evaluation. Fast appointments, same-day recommendations, and no charge if you\'re not approved.',
    reviewsP:     'Every review below comes from a verified NuggMD patient. See what people are saying about their experience getting a medical cannabis card online.',
    faqP:         'Curious about how NuggMD works or whether you qualify? Here are answers to the questions patients ask most.',
    howItWorksP:  'Getting your medical cannabis card through NuggMD takes about 15 minutes from start to finish. Here\'s exactly what to expect.',
    step1P:       'Fill out a short health questionnaire and upload a photo of your ID. Most patients finish this step in under five minutes.',
    step2P:       'You\'ll meet with a real, licensed doctor over secure video. It\'s a quick, friendly conversation — most visits are done in ten minutes or less.',
    step3P:       'Once approved, you\'ll get your recommendation right away with clear instructions for registering with your state. If you\'re not approved, you don\'t pay a cent.',
    statesP:      'Medical cannabis laws vary by state. Select yours to learn about qualifying conditions, costs, and what to expect in your area.',
    ctaP:         'Thousands of patients get their medical cannabis recommendation through NuggMD every month. The process is simple, the doctors are great, and you only pay if you\'re approved.',
    ctaFooter:    'Doctors available daily 8 AM – 10 PM  ·  Private & HIPAA-compliant  ·  Pay only if approved',
  },
}[variant] ?? {} as any;

const reviewGridCols = variant === 'blue-red'
  ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5'
  : variant === 'light'
    ? 'grid grid-cols-1 md:grid-cols-2 gap-6'
    : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6';

const aggregateRatingSchema = {
  '@context': 'https://schema.org',
  '@type': 'AggregateRating',
  itemReviewed: {
    '@type': 'Organization',
    name: 'NuggMD',
    url: 'https://www.nuggmd.com',
  },
  ratingValue: '4.9',
  reviewCount: String(verifiedCount),
  bestRating: '5',
  worstRating: '1',
};
---

<Base
  title={copy.metaTitle}
  description={copy.metaDesc}
  schema={aggregateRatingSchema}
>
  <!-- ========== HERO ========== -->
  {variant === 'blue-red' ? (
  <section class="text-white py-20 px-4 relative overflow-hidden" style="background-image: url('https://www.patagonia.com/blog/wp-content/uploads/2026/05/moisture-wicking-hero-100x67.jpg.webp'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-nugg-dark" style="opacity: 0.8;"></div>
    <div class="container-site relative z-10">
      <div class="flex items-center gap-3 mb-8">
        <StarRating rating={4.9} size="lg" />
        <div>
          <p class="text-white font-bold text-xl">4.9 / 5</p>
          <p class="text-nugg-tint text-sm">{verifiedDisplay} verified reviews</p>
        </div>
      </div>
      <h1 class="text-white mb-4 max-w-3xl">
        {copy.h1}
      </h1>
      <p class="text-nugg-tint text-lg max-w-2xl mb-8 leading-relaxed">
        {copy.heroP}
      </p>
      <a href="/reviews/" class="text-base px-8 py-4 inline-block font-bold border-2 border-white text-white rounded-brand hover:bg-white hover:text-nugg-dark transition-colors duration-200">
        Read All Reviews
      </a>
    </div>
  </section>
  ) : variant === 'light' ? (
  <section class="bg-nugg-dark text-white py-20 px-4">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Left: copy -->
        <div>
          <div class="inline-flex items-center gap-2 bg-nugg-shade rounded-full px-4 py-2 mb-6">
            <span class="text-nugg-red text-sm font-semibold">★ Verified Patient Reviews</span>
          </div>
          <h1 class="text-white mb-4">
            {copy.h1}
          </h1>
          <p class="text-nugg-tint text-lg mb-8 leading-relaxed">
            {copy.heroP}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="https://app.nuggmd.com/v2/signup/email?promo_code=TRYME20&utm_campaign=reviewlandingpages"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary text-base px-8 py-4"
            >
              Get 20% Off — Use Code TRYME20
            </a>
            <a href="/reviews/" class="text-base px-8 py-4 inline-block font-bold border-2 border-white text-white rounded-brand hover:bg-white hover:text-nugg-dark transition-colors duration-200">
              Read All Reviews
            </a>
          </div>
        </div>
        <!-- Right: rating + trust points -->
        <div class="flex flex-col gap-6">
          <div class="flex items-center gap-4">
            <StarRating rating={4.9} size="lg" />
            <div>
              <p class="text-white font-bold text-2xl">4.9 / 5</p>
              <p class="text-nugg-tint">{verifiedDisplay} verified reviews</p>
            </div>
          </div>
          <div class="bg-nugg-shade rounded-brand p-6">
            <ul class="space-y-3 text-nugg-tint">
              <li>✓ No approval = No charge</li>
              <li>✓ Results in as little as 15 minutes</li>
              <li>✓ HIPAA-compliant telemedicine</li>
              <li>✓ Licensed physicians in 31 states</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  ) : (
  <section class="bg-nugg-dark text-white py-20 px-4 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 70% 50%, #52B781 0%, transparent 60%), radial-gradient(circle at 20% 80%, #1E4A7D 0%, transparent 50%);"></div>
    <div class="container-site relative z-10 text-center">
      <div class="inline-flex items-center gap-2 bg-nugg-shade rounded-full px-4 py-2 mb-6">
        <span class="text-nugg-red text-sm font-semibold">★ Verified Patient Reviews</span>
      </div>
      <h1 class="text-white mb-4 max-w-3xl mx-auto">
        {copy.h1}
      </h1>
      <p class="text-nugg-tint text-lg max-w-2xl mx-auto mb-8 leading-relaxed">
        {copy.heroP}
      </p>
      <div class="flex items-center justify-center gap-3 mb-8">
        <StarRating rating={4.9} size="lg" />
        <div class="text-left">
          <p class="text-white font-bold text-xl">4.9 / 5</p>
          <p class="text-nugg-tint text-sm">{verifiedDisplay} verified reviews</p>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://app.nuggmd.com/v2/signup/email?promo_code=TRYME20&utm_campaign=reviewlandingpages"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-base px-8 py-4"
        >
          Get 20% Off — Use Code TRYME20
        </a>
        <a href="/reviews/" class="text-base px-8 py-4 inline-block font-bold border-2 border-white text-white rounded-brand hover:bg-white hover:text-nugg-dark transition-colors duration-200">
          Read All Reviews
        </a>
      </div>
    </div>
  </section>
  )}

  <!-- ========== TRUST BAR ========== -->
  <section class="bg-nugg-blue py-4 text-white">
    <div class="container-site">
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 text-center">
        <div class="flex items-center gap-2">
          <span class="text-nugg-red font-bold text-xl">{verifiedDisplay}</span>
          <span class="text-nugg-tint text-sm">Verified Recent Reviews</span>
        </div>
        <div class="hidden md:block text-nugg-shade font-bold">|</div>
        <div class="flex items-center gap-2">
          <span class="text-nugg-red font-bold text-xl">10,000+</span>
          <span class="text-nugg-tint text-sm">All-Time Reviews</span>
        </div>
        <div class="hidden md:block text-nugg-shade font-bold">|</div>
        <div class="flex items-center gap-2">
          <span class="text-nugg-error font-bold text-xl">4.9★</span>
          <span class="text-nugg-tint text-sm">Average Rating</span>
        </div>
        <div class="hidden md:block text-nugg-shade font-bold">|</div>
        <div class="flex items-center gap-2">
          <span class="text-nugg-red font-bold text-xl">31</span>
          <span class="text-nugg-tint text-sm">States Served</span>
        </div>
        <div class="hidden md:block text-nugg-shade font-bold">|</div>
        <div class="flex items-center gap-2">
          <span class="text-white font-bold text-xl">HIPAA</span>
          <span class="text-nugg-tint text-sm">Compliant</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FEATURED REVIEWS ========== -->
  <section class="section-white py-16 px-4">
    <div class="container-site">
      <div class="text-center mb-10">
        <h2 class="mb-3">{copy.h2Reviews}</h2>
        <p class="text-nugg-tint max-w-xl mx-auto">
          {copy.reviewsP}
        </p>
      </div>

      <div class={reviewGridCols}>
        {featuredReviews.map((review) => (
          <ReviewCard review={review} />
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/reviews/" class="btn-primary">
          See All Patient Reviews
        </a>
      </div>
    </div>
  </section>

  <!-- ========== FAQ PREVIEW ========== -->
  <section class="section-gray py-16 px-4">
    <div class="container-site">
      <div class="text-center mb-10">
        <h2 class="mb-3">{copy.h2Faq}</h2>
        <p class="text-nugg-tint max-w-xl mx-auto">
          {copy.faqP}
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        {previewFaqs.map((faq) => (
          <FAQItem question={faq.q} answer={faq.a} />
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/faqs/" class="btn-primary">
          View All FAQs
        </a>
      </div>
    </div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="section-white py-16 px-4">
    <div class="container-site">
      <div class="text-center mb-12">
        <h2 class="mb-3">How NuggMD Works</h2>
        <p class="text-nugg-tint max-w-xl mx-auto">
          {copy.howItWorksP}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
        <div class="text-center p-6 card">
          <div class="w-14 h-14 rounded-full bg-nugg-blue text-white text-2xl font-bold flex items-center justify-center mx-auto mb-4">1</div>
          <h3 class="text-nugg-blue mb-2">Register Online</h3>
          <p class="text-nugg-text text-sm">
            {copy.step1P}
          </p>
        </div>
        <div class="text-center p-6 card">
          <div class="w-14 h-14 rounded-full bg-nugg-blue text-white text-2xl font-bold flex items-center justify-center mx-auto mb-4">2</div>
          <h3 class="text-nugg-blue mb-2">See a Doctor</h3>
          <p class="text-nugg-text text-sm">
            {copy.step2P}
          </p>
        </div>
        <div class="text-center p-6 card">
          <div class="w-14 h-14 rounded-full bg-nugg-red text-white text-2xl font-bold flex items-center justify-center mx-auto mb-4">3</div>
          <h3 class="text-nugg-blue mb-2">Get Approved</h3>
          <p class="text-nugg-text text-sm">
            {copy.step3P}
          </p>
        </div>
      </div>

      <div class="text-center">
        <a
          href="https://app.nuggmd.com/v2/signup/email?promo_code=TRYME20&utm_campaign=reviewlandingpages"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary px-10 py-4 text-base"
        >
          Start Your Evaluation — 20% Off with TRYME20
        </a>
      </div>
    </div>
  </section>

  <!-- ========== STATES GRID ========== -->
  <section class="section-gray py-16 px-4">
    <div class="container-site">
      <div class="text-center mb-10">
        <h2 class="mb-3">Available in 31 States</h2>
        <p class="text-nugg-tint max-w-xl mx-auto">
          {copy.statesP}
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {stateEntries.map((entry) => (
          <a
            href={`/states/${entry.slug}/`}
            class="card flex flex-col items-center p-4 text-center hover:border-nugg-blue hover:shadow-md transition-all duration-200 group"
          >
            <span class="inline-block bg-nugg-blue text-white text-xs font-bold px-2 py-0.5 rounded mb-2 group-hover:bg-nugg-red transition-colors">
              {entry.abbr}
            </span>
            <span class="text-nugg-blue text-sm font-semibold leading-tight group-hover:text-nugg-shade transition-colors">
              {entry.state}
            </span>
          </a>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/states/" class="btn-primary">
          View All State Pages
        </a>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="bg-nugg-blue text-white py-20 px-4 text-center">
    <div class="container-site max-w-2xl mx-auto">
      <h2 class="text-white mb-4">{copy.h2Cta}</h2>
      <p class="text-nugg-tint text-lg mb-8 leading-relaxed">
        {copy.ctaP}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://app.nuggmd.com/v2/signup/email?promo_code=TRYME20&utm_campaign=reviewlandingpages"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-base px-10 py-4"
        >
          Get 20% Off — Code TRYME20
        </a>
      </div>
      <p class="text-nugg-tint text-sm mt-5 opacity-80">
        {copy.ctaFooter}
      </p>
    </div>
  </section>
</Base>
