---
import Base from '../../layouts/Base.astro';
import FAQItem from '../../components/FAQItem.astro';
import faqs from '../../data/faqs.json';

export async function getStaticPaths() {
  const stateEntries = faqs.filter((f) => f.state !== 'General');
  return stateEntries.map((entry) => ({
    params: { state: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const allFaqPairs = entry.sections.flatMap((s) => s.faqs);
const totalFaqs = allFaqPairs.length;

// State-specific NuggMD URL
const stateCardUrl = `https://www.nuggmd.com/medical-card/${entry.slug}/`;

// FAQPage schema
const faqPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqPairs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};

// Breadcrumb schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://nuggmdreviews.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'States',
      item: 'https://nuggmdreviews.com/states/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: `${entry.state} Medical Cannabis FAQs`,
      item: `https://nuggmdreviews.com/states/${entry.slug}/`,
    },
  ],
};

const schemaArray = [faqPageSchema, breadcrumbSchema];
---

<Base
  title={`NuggMD ${entry.state} FAQs — Medical Cannabis Card Guide`}
  description={`Get answers to ${totalFaqs} frequently asked questions about getting a medical cannabis card in ${entry.state} with NuggMD. Eligibility, costs, and how to use your card.`}
  schema={schemaArray}
>
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="bg-nugg-block2 border-b border-nugg-block1 py-2 px-4">
    <div class="container-site">
      <ol class="flex items-center gap-2 text-sm text-nugg-tint flex-wrap">
        <li><a href="/" class="hover:text-nugg-blue transition-colors">Home</a></li>
        <li class="text-nugg-block1">›</li>
        <li><a href="/states/" class="hover:text-nugg-blue transition-colors">States</a></li>
        <li class="text-nugg-block1">›</li>
        <li class="text-nugg-blue font-semibold">{entry.state}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-nugg-dark text-white py-14 px-4">
    <div class="container-site">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <span class="inline-block bg-nugg-red text-white text-sm font-bold px-3 py-1 rounded-full">
              {entry.abbr}
            </span>
            <span class="text-nugg-tint text-sm">{totalFaqs} FAQs</span>
          </div>
          <h1 class="text-white mb-3">
            NuggMD Patient FAQs — {entry.state}
          </h1>
          <p class="text-nugg-tint text-lg max-w-xl leading-relaxed">
            Answers to the most common questions about getting and using a medical cannabis card in {entry.state} through NuggMD.
          </p>
        </div>
        <div class="flex-shrink-0 flex flex-col gap-3 items-start md:items-end">
          <a
            href={`https://app.nuggmd.com/v2/signup/email?promo_code=TRYME20&utm_campaign=reviewlandingpages`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary whitespace-nowrap"
          >
            Get 20% Off — Code TRYME20
          </a>
          <p class="text-nugg-tint text-sm text-right">
            Licensed {entry.state} physicians available<br />8 AM – 10 PM daily
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section jump nav -->
  {entry.sections.length > 1 && (
    <section class="bg-nugg-blue py-4 px-4 sticky top-16 z-40">
      <div class="container-site">
        <div class="flex flex-wrap gap-2 justify-center">
          {entry.sections.map((section, i) => (
            <a
              href={`#section-${i}`}
              class="text-xs text-white hover:text-nugg-red font-semibold transition-colors px-3 py-1.5 rounded-full border border-nugg-shade hover:border-nugg-red"
            >
              {section.title}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ content -->
  <section class="section-white py-16 px-4">
    <div class="container-site max-w-3xl mx-auto">
      {entry.sections.map((section, i) => (
        <div id={`section-${i}`} class="mb-14 scroll-mt-28">
          <h2 class="mb-6 pb-3 border-b-2 border-nugg-block1">{section.title}</h2>
          <div>
            {section.faqs.map((faq) => (
              <FAQItem question={faq.q} answer={faq.a} />
            ))}
          </div>
        </div>
      ))}

      <!-- Inline CTA -->
      <div class="bg-nugg-blue rounded-brand p-8 text-center text-white mt-6">
        <h3 class="text-white mb-3">Ready to Get Your {entry.state} Medical Cannabis Card?</h3>
        <p class="text-nugg-tint mb-5 max-w-md mx-auto">
          Connect with a licensed {entry.state} physician online. Fast, private, and HIPAA-compliant. You only pay if approved.
        </p>
        <a
          href="https://app.nuggmd.com/v2/signup/email?promo_code=TRYME20&utm_campaign=reviewlandingpages"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Get 20% Off — Code TRYME20
        </a>
      </div>
    </div>
  </section>

  <!-- Related states -->
  <section class="section-gray py-12 px-4">
    <div class="container-site text-center">
      <h2 class="mb-4">Browse Other States</h2>
      <p class="text-nugg-tint mb-6">
        NuggMD operates in 31 states. Find state-specific FAQs and guides for your state.
      </p>
      <a href="/states/" class="btn-primary">View All States</a>
    </div>
  </section>
</Base>
